# OpenWeatherMap free-tier API key (required for weather integration - US4)
OPENWEATHER_API_KEY=

# Set to "rain", "clear", "cloudy" etc. to bypass the real weather API during demo
# Useful for hackathon presentations: MOCK_WEATHER=rain
MOCK_WEATHER=

# LLM explanation toggle (US4 stretch goal)
USE_LLM=false

# SQLite database file path (relative to backend/ working directory)
DB_PATH=./taipei.db

# Weather cache TTL in minutes
WEATHER_CACHE_TTL_MINUTES=30
