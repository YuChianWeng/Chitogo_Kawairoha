# OpenWeatherMap free-tier API key (required for weather integration - US4)
OPENWEATHER_API_KEY=

# Set to "rain", "clear", "cloudy" etc. to bypass the real weather API during demo
# Useful for hackathon presentations: MOCK_WEATHER=rain
MOCK_WEATHER=

# LLM explanation toggle (US4 stretch goal)
USE_LLM=false

# SQLite database file path (relative to backend/ working directory)
DB_PATH=./taipei.db

# Weather cache TTL in minutes
WEATHER_CACHE_TTL_MINUTES=30

# --- Dynamic Candidate Providers ---

# Google Places API key (New API). Required for live venue fetching.
# Get one at: https://console.cloud.google.com/apis/credentials
# Enable "Places API (New)" in your GCP project.
GOOGLE_PLACES_API_KEY=

# Crawler / social-source API URL (optional).
# If set, the aggregator will fetch trending venues from this endpoint.
# Expected format: GET <url>?district=...&interests=... -> {"venues": [...]}
CRAWLER_API_URL=

# Cache TTL for external candidate results (minutes). Default: 5
CANDIDATE_CACHE_TTL_MINUTES=5

# Google Gemini API
GEMINI_API_KEY=

# Apify API
APIFY_API_KEY=
